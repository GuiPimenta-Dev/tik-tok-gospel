# Copie para .env e preencha. NUNCA versione o .env real.
# load_dotenv NÃO sobrescreve env vars já exportadas no shell.

PEXELS_API_KEY=              # grátis em pexels.com/api
# Vozes: pool em config/<niche>.yaml (rotação). Ouça amostras: python -m src.voices

# LLM = SUBSCRIPTION (via Claude Code), não API paga.
#   - Local: funciona com seu login atual do Claude Code. NÃO setar ANTHROPIC_API_KEY
#     (se setar, o Claude Code usa a API PAGA em vez da assinatura).
#   - Cron/cloud: gere um token de 1 ano com `claude setup-token` e exporte:
# CLAUDE_CODE_OAUTH_TOKEN=
# CLAUDE_MODEL=               # opcional: força um modelo específico no `claude -p`

# ELEVENLABS_API_KEY: já exportado no seu ambiente — não precisa aqui.
